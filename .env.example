# cn-roms — RomM on kaiser.lan, dual-ingress roms.kaiser.lan + roms.lab.gn.al.

# Repo-wide identifiers (match cn-media's .env)
HEADSCALE_DOMAIN=hs.gn.al
LAB_DOMAIN=lab.gn.al
TAILNET_DOMAIN=ts.gn.al
INFRA_VPS_TAILNET_IP=100.64.0.1

# Tailscale preauth key for ts-roms (tag:svc, 24 h). Mint via:
#   ssh hs.gn.al 'docker exec cloudnet-headscale-1 \
#     headscale preauthkeys create -u 2 --tags tag:svc --expiration 24h'
# (-u 2 is gonzaloab@gmail.com's numeric user ID; verify with `headscale users list`)
ROMS_AUTHKEY=

# RomM application secrets
ROMM_SECRET=                  # openssl rand -hex 32
DB_PASSWORD=                  # any strong password (used by romm-db + romm)
DB_ROOT_PASSWORD=             # MariaDB root password (separate from app user)

# Optional metadata providers (fill what you have; leave empty to disable each).
# HASHEOUS is enabled unconditionally in docker-compose.yml — no key required.
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=
SCREENSCRAPER_USER=
SCREENSCRAPER_PASSWORD=
RETROACHIEVEMENTS_API_KEY=
STEAMGRIDDB_API_KEY=

USER_ID=1000
GROUP_ID=1000
TIMEZONE=America/Los_Angeles
